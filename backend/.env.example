# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/examchecker?schema=public"

# Python Service
PYTHON_SERVICE_URL=http://localhost:8000

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
