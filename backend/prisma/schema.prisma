generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Exercise {
  id            String         @id @default(uuid())
  title         String
  pdfUrl        String
  status        ExerciseStatus @default(DRAFT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  extractedText String?
  checkpoints   Checkpoint[]
  conversations Conversation[]
  submissions   Submission[]

  @@map("exercises")
}

model Checkpoint {
  id                String             @id @default(uuid())
  exerciseId        String
  order             Int
  description       String
  pattern           String
  caseSensitive     Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  checkpointResults CheckpointResult[]
  exercise          Exercise           @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("checkpoints")
}

model Conversation {
  id         String           @id @default(uuid())
  exerciseId String
  role       ConversationRole
  content    String
  createdAt  DateTime         @default(now())
  type       ConversationType @default(CHECKPOINT)
  exercise   Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("conversations")
}

model Submission {
  id                 String              @id @default(uuid())
  exerciseId         String
  fileName           String
  fileUrl            String
  fileType           String
  content            String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  gradingResult      GradingResult?
  exercise           Exercise            @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  submissionStudents SubmissionStudent[]

  @@index([exerciseId])
  @@map("submissions")
}

model SubmissionStudent {
  id           String     @id @default(uuid())
  submissionId String
  studentId    String
  createdAt    DateTime   @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([submissionId, studentId])
  @@index([submissionId])
  @@index([studentId])
  @@map("submission_students")
}

model GradingResult {
  id                String             @id @default(uuid())
  submissionId      String             @unique
  totalCheckpoints  Int
  passedCheckpoints Int
  score             Float
  passed            Boolean
  gradedAt          DateTime           @default(now())
  teacherScore      Float?
  checkpointResults CheckpointResult[]
  submission        Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("grading_results")
}

model CheckpointResult {
  id              String        @id @default(uuid())
  gradingResultId String
  checkpointId    String
  matched         Boolean
  matchedSnippets String[]
  createdAt       DateTime      @default(now())
  checkpoint      Checkpoint    @relation(fields: [checkpointId], references: [id], onDelete: Cascade)
  gradingResult   GradingResult @relation(fields: [gradingResultId], references: [id], onDelete: Cascade)

  @@index([gradingResultId])
  @@index([checkpointId])
  @@map("checkpoint_results")
}

model Student {
  id                 String              @id @default(uuid())
  studentIdentifier  String              @unique
  firstName          String
  lastName           String
  email              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  submissionStudents SubmissionStudent[]

  @@map("students")
}

enum ExerciseStatus {
  DRAFT
  APPROVED
  GRADED
}

enum ConversationRole {
  PROFESSOR
  ASSISTANT
}

enum ConversationType {
  CHECKPOINT
  PATTERN
}
