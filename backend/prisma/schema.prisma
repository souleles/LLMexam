generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Exercise {
  id             String         @id @default(uuid())
  title          String
  fileName       String?
  pdfUrl         String
  status         ExerciseStatus @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  extractedText  String?
  databaseSchema String?
  teacherid      String
  exerciseType   ExerciseType   @default(EXERCISE)
  checkpoints    Checkpoint[]
  rules          Rule[]
  conversations  Conversation[]
  users          users          @relation(fields: [teacherid], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "exercises_fk")
  submissions    Submission[]

  @@map("exercises")
}

model Checkpoint {
  id                 String             @id @default(uuid())
  exerciseId         String
  order              Int
  description        String
  pattern            String
  caseSensitive      Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  patternDescription String
  indicatorSolution  String
  checkpointResults  CheckpointResult[]
  exercise           Exercise           @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("checkpoints")
}

model Rule {
  id         String   @id @default(uuid())
  exerciseId String
  content    String
  order      Int
  createdAt  DateTime @default(now())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("rules")
}

model Conversation {
  id         String           @id @default(uuid())
  exerciseId String
  role       ConversationRole
  content    String
  createdAt  DateTime         @default(now())
  type       ConversationType @default(CHECKPOINT)
  exercise   Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("conversations")
}

model Submission {
  id                 String              @id @default(uuid())
  exerciseId         String
  fileName           String
  fileUrl            String
  fileType           String
  content            String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  gradingResult      GradingResult?
  submissionStudents SubmissionStudent[]
  exercise           Exercise            @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("submissions")
}

model SubmissionStudent {
  id           String     @id @default(uuid())
  submissionId String
  studentId    String
  createdAt    DateTime   @default(now())
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, studentId])
  @@unique([submissionId, studentId], map: "submission_students_un")
  @@index([submissionId])
  @@index([studentId])
  @@map("submission_students")
}

model GradingResult {
  id                   String             @id @default(uuid())
  submissionId         String             @unique
  totalCheckpoints     Int
  passedCheckpoints    Int?
  score                Float?
  gradedAt             DateTime           @default(now())
  teacherScore         Float?
  llmPassedCheckpoints Int?
  llmScore             Float?
  projectReport        String?
  projectReportAt      DateTime?
  checkpointResults    CheckpointResult[]
  submission           Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("grading_results")
}

model CheckpointResult {
  id                      String        @id @default(uuid())
  gradingResultId         String
  checkpointId            String
  matched                 Boolean
  matchedSnippets         String[]
  createdAt               DateTime      @default(now())
  llmMatched              Boolean?
  llmMatchedSnippets      String[]      @default([])
  regexFailureExplanation String?
  teacherAccepted         Boolean?
  checkpoint              Checkpoint    @relation(fields: [checkpointId], references: [id], onDelete: Cascade)
  gradingResult           GradingResult @relation(fields: [gradingResultId], references: [id], onDelete: Cascade)

  @@unique([gradingResultId, checkpointId])
  @@index([gradingResultId])
  @@index([checkpointId])
  @@map("checkpoint_results")
}

model Student {
  id                 String              @id @default(uuid())
  studentIdentifier  String
  firstName          String
  lastName           String
  email              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  miniReport         String?
  miniReportAt       DateTime?
  teacherid          String
  users              users               @relation(fields: [teacherid], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "students_fk")
  submissionStudents SubmissionStudent[]

  @@unique([teacherid, studentIdentifier])
  @@map("students")
}

model users {
  id        String     @id @default(uuid())
  username  String     @unique
  password  String
  role      String     @default("teacher")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now())
  exercises Exercise[]
  students  Student[]
}

enum ExerciseStatus {
  DRAFT
  APPROVED
  GRADED
}

enum ExerciseType {
  EXERCISE
  PROJECT
}

enum ConversationRole {
  PROFESSOR
  ASSISTANT
}

enum ConversationType {
  CHECKPOINT
  PATTERN
}
